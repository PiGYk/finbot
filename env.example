# ==========================================
# TELEGRAM CONFIGURATION
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_secure_webhook_secret_here

# ==========================================
# CLAUDE API CONFIGURATION
# ==========================================
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ==========================================
# FIREFLY III CONFIGURATION
# ==========================================
FIREFLY_BASE_URL=http://firefly:8080
FIREFLY_ACCESS_TOKEN=your_firefly_access_token_here

# ==========================================
# DEFAULT SETTINGS
# ==========================================
DEFAULT_SOURCE_ACCOUNT=Готівка
DEFAULT_CURRENCY=UAH
BOT_TIMEZONE=Europe/Kyiv

# ==========================================
# MULTI-PROFILE CONFIGURATION (optional)
# ==========================================
ALLOWED_CHAT_IDS=123456789,987654321
PROFILES_FILE=/app/data/bot/profiles.json
BOT_DATA_ROOT=/app/data/bot

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ==========================================
# REMINDERS & SCHEDULER
# ==========================================
REMINDER_POLL_SECONDS=30
REMINDER_DATA_FILE=/app/data/reminders.json

# ==========================================
# CATEGORY RULES
# ==========================================
CATEGORY_RULES_FILE=/app/data/category_rules.json

# ==========================================
# BUDGETS
# ==========================================
BUDGET_DATA_FILE=/app/data/budgets.json

# ==========================================
# API RATE LIMITING (optional)
# ==========================================
# Максимум запитів на користувача за хвилину
CLAUDE_RATE_LIMIT=10
FIREFLY_RATE_LIMIT=20

# ==========================================
# RETRY CONFIGURATION
# ==========================================
# Максимум спроб для Claude API
CLAUDE_RETRY_MAX=3
#초기 затримка в секундах
CLAUDE_RETRY_INITIAL_DELAY=1
# Максимальна затримка в секундах
CLAUDE_RETRY_MAX_DELAY=10
